  top: 14px;
  right: 14px;
  z-index: 1;
  width: 38px;
  height: 38px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.08);
  color: var(--text);
  font-size: 1.4rem;
}

.auth-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 22px;
  padding: 6px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.05);
}

.auth-tabs button {
  min-height: 42px;
  border: 0;
  border-radius: 8px;
  background: transparent;
  color: var(--muted);
  font-weight: 800;
}

.auth-tabs button.active {
  color: #06100b;
  background: var(--green);
}

.auth-card h2 {
  margin: 0 0 22px;
  font-size: 2rem;
}

.form-block {
  display: grid;
  gap: 8px;
  margin-bottom: 16px;
}

.form-block label {
  color: var(--muted);
  font-size: 0.9rem;
}

.form-block input {
  min-height: 52px;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 0 14px;
  outline: none;
  background: rgba(255, 255, 255, 0.07);
  color: var(--text);
}

.form-block input:focus {
  border-color: rgba(67, 240, 162, 0.6);
  box-shadow: 0 0 0 4px rgba(67, 240, 162, 0.1);
}

.form-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.form-main-button {
  flex: 1;
}

.text-button {
  margin-top: 14px;
  border: 0;
  background: transparent;
  color: var(--cyan);
  padding: 0;
}

.form-message,
.logged-in-box {
  border: 1px solid rgba(255, 206, 84, 0.26);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 16px;
  color: var(--gold);
  background: rgba(255, 206, 84, 0.08);
}

.logged-in-box {
  margin: 18px 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.auth-badges {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 28px;
}

.auth-badges span {
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 10px 12px;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.05);
}

.auth-empty {
  min-height: 60vh;
  display: grid;
  align-content: center;
}

.site-footer {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
  padding: 28px 0 42px;
  display: flex;
  justify-content: space-between;
  gap: 24px;
  color: var(--muted);
  border-top: 1px solid var(--line);
}

.site-footer strong {
  color: var(--text);
}

.site-footer p {
  margin: 8px 0 0;
}

.footer-links {
  display: flex;
  gap: 18px;
}

@keyframes floatPanel {
  0%, 100% { transform: rotateX(4deg) rotateY(-7deg) translateY(0); }
  50% { transform: rotateX(4deg) rotateY(-7deg) translateY(-10px); }
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: translateY(16px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@media (max-width: 900px) {
  .nav-shell {
    height: auto;
    padding: 14px 0;
    flex-wrap: wrap;
  }

  .nav-links {
    order: 3;
    width: 100%;
    justify-content: space-between;
    overflow-x: auto;
  }

  .hero-section,
  .dashboard-hero,
  .map-hero,
  .feature-band,
  .showcase-section,
  .profile-shell {
    grid-template-columns: 1fr;
  }

  .auth-modal {
    grid-template-columns: 1fr;
    max-height: calc(100vh - 32px);
    overflow-y: auto;
  }

  .hero-section {
    min-height: auto;
    padding-top: 46px;
  }

  .console-card {
    min-height: 440px;
    transform: none;
  }

  .trust-row,
  .course-grid,
  .quest-grid,
  .feature-list,
  .lesson-lab-grid {
    grid-template-columns: 1fr;
  }

  .world-map {
    min-height: auto;
    padding: 22px;
    display: grid;
    gap: 14px;
  }

  .route-line {
    display: none;
  }

  .world-node {
    position: static;
    width: 100%;
    grid-template-columns: 58px 1fr;
    align-items: center;
    justify-items: start;
    text-align: left;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.045);
  }

  .site-footer {
    flex-direction: column;
  }
}

@media (max-width: 560px) {
  .page,
  .nav-shell,
  .site-footer {
    width: min(100% - 24px, 1180px);
  }

  .brand-mark span:last-child {
    display: none;
  }

  .nav-action {
    padding: 0 12px;
  }

  .hero-copy h1 {
    font-size: 3.2rem;
  }

  .console-stats,
  .trust-row {
    grid-template-columns: 1fr;
  }

  .map-preview {
    margin: 18px;
  }

  .subject-orbit {
    margin: 18px;
  }

  .orbit-card {
    width: 92px;
  }

  .review-strip div {
    grid-template-columns: 1fr;
  }

  .chapter-header {
    flex-direction: column;
  }

  .form-actions,
  .hero-actions {
    flex-direction: column;
  }

  .btn {
    width: 100%;
  }
}
