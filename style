  gap: 12px;
  font-weight: 800;
  color: var(--text);
}

.brand-symbol {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(67, 240, 162, 0.55);
  border-radius: 8px;
  background: linear-gradient(145deg, rgba(67, 240, 162, 0.18), rgba(88, 216, 255, 0.08));
  color: var(--green);
  box-shadow: 0 0 28px rgba(67, 240, 162, 0.18);
  font-size: 1.22rem;
}

.nav-links {
  display: flex;
